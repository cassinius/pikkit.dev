{
	"name": "pikkit",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"db:boot": "bun db/scripts/bootstrap.ts",
		"db:clear": "bun db/scripts/clear.ts",
		"db:gen": "drizzle-kit generate --config db/drizzle.config.ts",
		"db:mig": "bun run db:boot && bun db/scripts/migrate.ts",
		"db:push": "bun run db:boot && drizzle-kit push --config db/drizzle.config.ts",
		"db:seed": "bun run db:mig && bun db/seeds/playbooks.ts",
		"db:search": "bun db/scripts/search.ts",
		"db:studio": "bun run db:boot && drizzle-kit studio --config db/drizzle.config.ts",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.59.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^25.6.2",
		"drizzle-kit": "^0.31.10",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.8",
		"typescript": "^6.0.3",
		"vite": "^8.0.11"
	},
	"dependencies": {
		"@electric-sql/pglite": "^0.4.5",
		"@tailwindcss/vite": "^4.3.0",
		"drizzle-orm": "^0.45.2",
		"tailwindcss": "^4.3.0"
	}
}
